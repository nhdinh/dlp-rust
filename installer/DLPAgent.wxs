<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

    <!--
      DLP Agent MSI Installer  -  WiX v4+ source

      Prerequisites:
        - WiX v4+ toolset (https://wixtoolset.org/)
          Install:  dotnet tool install --global wix
        - WiX extensions:
          wix extension add WixToolset.Util.wixext
          wix extension add WixToolset.UI.wixext

      Build:
        build.ps1         - full build script (recommended)
        Or manually:
          cargo build --release -p dlp-agent -p dlp-user-ui
          wix build -ext WixToolset.Util.wixext -ext WixToolset.UI.wixext -d SourceDir=<repo-root> -o dist\DLPAgent.msi DLPAgent.wxs
    -->

    <!-- ===================================================================
         PACKAGE METADATA
         In WiX v4+, the Package element replaces the v3 Product element
         and combines product and package attributes.
         =================================================================== -->
    <Package Name="DLP Agent"
             Language="1033"
             Version="1.0.0.0"
             Manufacturer="Enterprise DLP"
             UpgradeCode="A3F8D2C1-7B4E-9F6D-8A3E-2C1B5D4A7F9E"
             Codepage="1252"
             InstallerVersion="500"
             Compressed="yes"
             Scope="perMachine">

        <SummaryInformation Description="DLP Agent - Enterprise Data Loss Prevention Endpoint Agent"
                           Manufacturer="Enterprise DLP"
                           Keywords="DLP,Endpoint,Security" />

        <!-- Disallow downgrades -->
        <MajorUpgrade Schedule="afterInstallExecute"
                      DowngradeErrorMessage="A newer version of DLP Agent is already installed." />

        <!-- Cabinet settings (replaces v3 Media element) -->
        <MediaTemplate EmbedCab="yes"
                       CompressionLevel="high" />

        <!-- ================================================================
             DIRECTORY TREE
             C:\Program Files\DLP\
               +-- dlp-agent.exe
               +-- dlp-user-ui.exe
               +-- dlp-admin-cli.exe
               +-- config\
               +-- logs\
             ================================================================ -->
        <StandardDirectory Id="ProgramFilesFolder">
            <Directory Id="DLPINSTALLFOLDER" Name="DLP">

                <!-- Config directory -->
                <Directory Id="DLPCONFIGFOLDER" Name="config">
                    <Component Id="DLP_CONFIG_DIR" Guid="*">
                        <CreateFolder>
                            <util:PermissionEx User="SYSTEM"
                                              GenericAll="yes" />
                            <util:PermissionEx User="Administrators"
                                              GenericAll="yes" />
                        </CreateFolder>
                    </Component>
                </Directory>

                <!-- Audit log directory -->
                <Directory Id="DLPLOGSFOLDER" Name="logs">
                    <Component Id="DLP_LOGS_DIR" Guid="*">
                        <CreateFolder>
                            <util:PermissionEx User="SYSTEM"
                                              GenericAll="yes" />
                            <util:PermissionEx User="Administrators"
                                              GenericAll="yes" />
                            <util:PermissionEx User="Everyone"
                                              GenericRead="yes" />
                        </CreateFolder>
                    </Component>
                </Directory>

                <!-- ========================================================
                     BINARY COMPONENTS
                     ======================================================== -->

                <!-- DLP Agent Windows Service binary -->
                <Component Id="DLPAGENTEXE" Guid="*">
                    <File Id="DLPAGENTEXE_FILE"
                          Name="dlp-agent.exe"
                          Source="$(SourceDir)\target\release\dlp-agent.exe"
                          KeyPath="yes" />

                    <!-- Windows Service registration -->
                    <ServiceInstall Id="DLPAGENTSERVICE"
                                    Type="ownProcess"
                                    Name="dlp-agent"
                                    DisplayName="DLP Agent"
                                    Description="Enterprise DLP Endpoint Agent - monitors file operations, USB devices, and SMB shares."
                                    Start="auto"
                                    Account="LocalSystem"
                                    ErrorControl="normal"
                                    Vital="yes" />

                    <!-- Start on install, stop on uninstall -->
                    <ServiceControl Id="DLPAGENTSERVICECONTROL"
                                    Name="dlp-agent"
                                    Start="install"
                                    Stop="both"
                                    Remove="uninstall"
                                    Wait="yes" />
                </Component>

                <!-- DLP User UI subprocess binary -->
                <Component Id="DLPUSERUIEXE" Guid="*">
                    <File Id="DLPUSERUIEXE_FILE"
                          Name="dlp-user-ui.exe"
                          Source="$(SourceDir)\target\release\dlp-user-ui.exe"
                          KeyPath="yes" />
                </Component>

                <!-- dlp-admin-cli tool -->
                <Component Id="DLPADMINCLIEXE" Guid="*">
                    <File Id="DLPADMINCLIEXE_FILE"
                          Name="dlp-admin-cli.exe"
                          Source="$(SourceDir)\target\release\dlp-admin-cli.exe"
                          KeyPath="yes" />
                </Component>

            </Directory>
        </StandardDirectory>

        <!-- ================================================================
             FEATURE TREE
             ================================================================ -->
        <Feature Id="ProductFeature"
                 Title="DLP Agent"
                 Level="1"
                 ConfigurableDirectory="DLPINSTALLFOLDER"
                 Display="expand"
                 AllowAbsent="no">

            <ComponentRef Id="DLPAGENTEXE" />
            <ComponentRef Id="DLPUSERUIEXE" />
            <ComponentRef Id="DLPADMINCLIEXE" />
            <ComponentRef Id="DLP_CONFIG_DIR" />
            <ComponentRef Id="DLP_LOGS_DIR" />
        </Feature>

        <!-- ================================================================
             ADD/REMOVE PROGRAMS REGISTRY
             ================================================================ -->
        <Component Id="RegistryEntries" Guid="*" Directory="DLPINSTALLFOLDER">
            <RegistryValue Root="HKLM"
                           Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\DLPAgent"
                           Type="string"
                           Value="DLP Agent"
                           Name="DisplayName"
                           KeyPath="yes" />

            <RegistryValue Root="HKLM"
                           Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\DLPAgent"
                           Type="string"
                           Value="[DLPINSTALLFOLDER]dlp-agent.exe"
                           Name="DisplayIcon" />

            <RegistryValue Root="HKLM"
                           Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\DLPAgent"
                           Type="string"
                           Value="Enterprise DLP"
                           Name="Publisher" />

            <RegistryValue Root="HKLM"
                           Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\DLPAgent"
                           Type="string"
                           Value="1.0.0"
                           Name="DisplayVersion" />

            <RegistryValue Root="HKLM"
                           Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\DLPAgent"
                           Type="integer"
                           Value="1"
                           Name="NoModify" />

            <RegistryValue Root="HKLM"
                           Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\DLPAgent"
                           Type="integer"
                           Value="1"
                           Name="NoRepair" />

            <RegistryValue Root="HKLM"
                           Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\DLPAgent"
                           Type="integer"
                           Value="15000"
                           Name="EstimatedSize" />
        </Component>

        <Feature Id="RegistryFeature" Title="Registry" Level="1">
            <ComponentRef Id="RegistryEntries" />
        </Feature>

        <!-- ================================================================
             UI - WiX v4 UI extension
             ================================================================ -->
        <Property Id="WIXUI_INSTALLDIR" Value="DLPINSTALLFOLDER" />
        <Property Id="ARPPRODUCTICON" Value="DLPAGENTEXE_FILE" />
        <Property Id="ARPHELPLINK" Value="mailto:dlp-admin@corp.local" />

        <UI>
            <ui:WixUI Id="WixUI_InstallDir"
                      xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
                      InstallDirectory="DLPINSTALLFOLDER" />
        </UI>

        <!-- ================================================================
             CUSTOM ACTION: launch dlp-admin-cli set-password after install
             ================================================================ -->
        <CustomAction Id="LaunchSetPassword"
                      FileRef="DLPADMINCLIEXE_FILE"
                      ExeCommand="set-password"
                      Execute="deferred"
                      Impersonate="no"
                      Return="ignore" />

        <InstallExecuteSequence>
            <Custom Action="LaunchSetPassword"
                    After="InstallFinalize">NOT Installed</Custom>
        </InstallExecuteSequence>

    </Package>
</Wix>
