{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DLP Agent UI",
  "identifier": "com.dlp.agent.ui",
  "version": "0.1.0",
  "build": {
    "beforeBuildCommand": "cargo build --release",
    "beforeDevCommand": "cargo build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DLP Agent",
        "width": 480,
        "height": 360,
        "resizable": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": []
  }
}
