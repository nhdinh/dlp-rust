# Cargo
target/

# Rust build artifacts
*.exe
*.pdb
Cargo.lock

# Environment
.env
.env.*

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# Logs
*.log
# Audit log files generated by the agent at runtime or during test runs
# (written to CWD as a fallback when C:\ProgramData\DLP\logs is not writable)
audit.jsonl
audit.*.jsonl

# IDE
.vscode/
.idea/
*.iml

# Local config overrides
config.local.*

# Tauri generated (re-created on build)
dlp-agent/src-tauri/gen/

# Installer build output
installer/dist/

# SQLite databases (runtime artifacts)
*.db
*.db-shm
*.db-wal

# Claude session config (local machine-specific, never committed)
.claude/

# RTK / alternate target dirs
target-test/

# Beads / Dolt files (added by bd init)
.dolt/
.beads-credential-key
